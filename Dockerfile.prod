FROM node:20-alpine AS build

WORKDIR /app

COPY app/package*.json ./
RUN npm ci

COPY app/ ./
# Local production image:
# - Build with Vite directly (skip `tsc -b`) to avoid blocking on existing TS errors.
# - Use development mode so `.env.development` is loaded.
RUN npx vite build --mode development

FROM nginx:1.27-alpine

COPY app/src/nginx/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
